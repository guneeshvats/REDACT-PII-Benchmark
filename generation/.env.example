# Standalone runner envs used by standalone_pipeline/smoke_test/run_smoke_test.py
# Note: variable names follow current script expectations.

# Claude Opus proxy (standalone scripts currently expect hyphen in key)
SYGRA_CLAUDE_OPUS4-6_URL=https://<sygra-claude-opus-endpoint>

# GPT-4o-mini proxy
SYGRA_GPT-4O-MINI_URL=https://<sygra-gpt4o-mini-endpoint>
SYGRA_GPT-4O-MINI_TOKEN=<token>

# Optional direct Anthropic
ANTHROPIC_API_KEY=<key>
